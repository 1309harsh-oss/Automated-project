        "text": "=Article Title: {{ $('Edit Fields').item.json.title }}\n\nArticle Summary: {{ $('Edit Fields').item.json.summary }}\n\nArticle Link: {{ $('Edit Fields').item.json.link }}",
        "options": {
          "systemMessage": "You are a social media expert specializing in Twitter/X content.\n\nCreate an engaging tweet that:\n1. Captures attention with a strong hook\n2. Summarizes the key insight from the article\n3. Includes the article link\n4. Uses 1-2 relevant hashtags\n5. Is EXACTLY 280 characters or less\n\nIMPORTANT: Count characters carefully. The tweet MUST NOT exceed 280 characters including spaces, hashtags, and the link.\n\nReturn ONLY the tweet text, nothing else."
        }
